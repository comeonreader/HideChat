# 项目根目录，默认当前目录
PROJECT_ROOT=.

# Codex 命令
CODEX_CMD=codex

# 是否允许自动执行 docker compose 验证
ENABLE_DOCKER_VERIFY=true

# 后端验证命令
BACKEND_TEST_CMD=cd backend && mvn test

# 前端验证命令
FRONTEND_TEST_CMD=cd frontend && npm test && npm run build

# 容器启动命令
DOCKER_UP_CMD=docker compose up -d --build
DOCKER_PS_CMD=docker compose ps
DOCKER_DOWN_CMD=docker compose down

# 健康检查命令
BACKEND_HEALTH_CMD=curl -fsS http://localhost:8080/actuator/health
FRONTEND_HEALTH_CMD=curl -fsS http://localhost:3000

# 阶段执行产物目录
STATE_DIR=.openclaw/state
LOG_DIR=.openclaw/logs
